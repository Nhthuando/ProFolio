generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model contacts {
  id           Int        @id @default(autoincrement())
  portfolio_id Int
  name         String     @db.VarChar(255)
  email        String     @db.VarChar(255)
  message      String     @db.Text
  is_read      Boolean?   @default(false)
  created_at   DateTime?  @default(now()) @db.DateTime(0)
  portfolios   portfolios @relation(fields: [portfolio_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "contacts_ibfk_1")

  @@index([portfolio_id], map: "portfolio_id")
}

model educations {
  id           Int        @id @default(autoincrement())
  portfolio_id Int
  school       String     @db.VarChar(255)
  major        String?    @db.VarChar(255)
  degree       String?    @db.VarChar(100)
  start_date   DateTime   @db.Date
  end_date     DateTime?  @db.Date
  is_current   Boolean?   @default(false)
  order_index  Int?       @default(0)
  portfolios   portfolios @relation(fields: [portfolio_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "educations_ibfk_1")

  @@index([portfolio_id], map: "portfolio_id")
}

model experiences {
  id           Int        @id @default(autoincrement())
  portfolio_id Int
  company      String     @db.VarChar(255)
  position     String     @db.VarChar(255)
  description  String?    @db.Text
  start_date   DateTime   @db.Date
  end_date     DateTime?  @db.Date
  is_current   Boolean?   @default(false)
  order_index  Int?       @default(0)
  portfolios   portfolios @relation(fields: [portfolio_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "experiences_ibfk_1")

  @@index([portfolio_id], map: "portfolio_id")
}

model portfolios {
  id           Int            @id @default(autoincrement())
  user_id      Int
  title        String         @db.VarChar(255)
  slug         String         @unique(map: "slug") @db.VarChar(255)
  description  String?        @db.Text
  avatar       String?        @db.VarChar(500)
  is_published Boolean?       @default(false)
  template     String?        @default("minimal") @db.VarChar(100)
  theme_color  String?        @default("#6366f1") @db.VarChar(20)
  created_at   DateTime?      @default(now()) @db.DateTime(0)
  updated_at   DateTime?      @default(now()) @db.DateTime(0)
  contacts     contacts[]
  educations   educations[]
  experiences  experiences[]
  users        users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "portfolios_ibfk_1")
  projects     projects[]
  skills       skills[]
  social_links social_links[]

  @@index([user_id], map: "user_id")
}

model projects {
  id           Int        @id @default(autoincrement())
  portfolio_id Int
  title        String     @db.VarChar(255)
  description  String?    @db.Text
  thumbnail    String?    @db.VarChar(500)
  demo_url     String?    @db.VarChar(500)
  github_url   String?    @db.VarChar(500)
  tags         String?    @db.VarChar(500)
  order_index  Int?       @default(0)
  created_at   DateTime?  @default(now()) @db.DateTime(0)
  portfolios   portfolios @relation(fields: [portfolio_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "projects_ibfk_1")

  @@index([portfolio_id], map: "portfolio_id")
}

model skills {
  id           Int        @id @default(autoincrement())
  portfolio_id Int
  name         String     @db.VarChar(255)
  level        Int?       @default(0)
  category     String?    @db.VarChar(100)
  order_index  Int?       @default(0)
  portfolios   portfolios @relation(fields: [portfolio_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "skills_ibfk_1")

  @@index([portfolio_id], map: "portfolio_id")
}

model social_links {
  id           Int        @id @default(autoincrement())
  portfolio_id Int
  platform     String     @db.VarChar(100)
  url          String     @db.VarChar(500)
  order_index  Int?       @default(0)
  portfolios   portfolios @relation(fields: [portfolio_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "social_links_ibfk_1")

  @@index([portfolio_id], map: "portfolio_id")
}

model users {
  id         Int          @id @default(autoincrement())
  email      String       @unique(map: "email") @db.VarChar(255)
  password   String       @db.VarChar(255)
  name       String       @db.VarChar(255)
  avatar     String?      @db.VarChar(500)
  created_at DateTime?    @default(now()) @db.DateTime(0)
  updated_at DateTime?    @default(now()) @db.DateTime(0)
  portfolios portfolios[]
}
